            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"theme-color\" content=\"#111827\">\n  <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\">\n  <link rel=\"manifest\" href=\"/manifest.json\">\n  <link rel=\"icon\" href=\"/assets/icon-192.png\">\n  <link rel=\"apple-touch-icon\" href=\"/assets/icon-192.png\">\n  <title>Camanchaca CMS</title>\n  <link rel=\"stylesheet\" href=\"/css/variables.css\">\n  <link rel=\"stylesheet\" href=\"/css/reset.css\">\n  <link rel=\"stylesheet\" href=\"/css/main.css\">\n  <script src=\"/socket.io/socket.io.js\"></script>\n</head>\n<body>\n  <button class=\"mobile-menu-btn\" id=\"mobileMenuBtn\" aria-label=\"Toggle navigation menu\" aria-expanded=\"false\" aria-controls=\"sidebar\">\n    <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/></svg>\n  </button>\n  <div class=\"sidebar-backdrop\" id=\"sidebarBackdrop\"></div>\n  <nav class=\"sidebar\" id=\"sidebar\">\n    <div class=\"sidebar-header\">\n      <div class=\"logo\">\n        <img src=\"/assets/icon-192.png\" width=\"28\" height=\"28\" alt=\"Camanchaca CMS\" style=\"border-radius:4px\">\n        <span>Camanchaca CMS</span>\n      </div>\n      <div class=\"workspace-switcher\" id=\"workspaceSwitcher\"></div>\n    </div>\n    <ul class=\"nav-links\">\n      <li><a href=\"#/\" class=\"nav-link active\" data-view=\"dashboard\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/>\n          <rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/>\n        </svg>\n        <span>Pantallas</span>\n      </a></li>\n      <li><a href=\"#/content\" class=\"nav-link\" data-view=\"content\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z\"/>\n          <polyline points=\"13 2 13 9 20 9\"/>\n        </svg>\n        <span>Contenido</span>\n      </a></li>\n      <li><a href=\"#/playlists\" class=\"nav-link\" data-view=\"playlists\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <line x1=\"8\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"8\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"8\" y1=\"18\" x2=\"21\" y2=\"18\"/>\n          <line x1=\"3\" y1=\"6\" x2=\"3.01\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"3.01\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"3.01\" y2=\"18\"/>\n        </svg>\n        <span>Listas de reproducción</span>\n      </a></li>\n      <li><a href=\"#/layouts\" class=\"nav-link\" data-view=\"layouts\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\"/><line x1=\"9\" y1=\"21\" x2=\"9\" y2=\"9\"/>\n        </svg>\n        <span>Diseños</span>\n      </a></li>\n      <li><a href=\"#/schedule\" class=\"nav-link\" data-view=\"schedule\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/>\n        </svg>\n        <span>Horario</span>\n      </a></li>\n      <li><a href=\"#/walls\" class=\"nav-link\" data-view=\"walls\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <rect x=\"2\" y=\"3\" width=\"9\" height=\"8\" rx=\"1\"/><rect x=\"13\" y=\"3\" width=\"9\" height=\"8\" rx=\"1\"/>\n          <rect x=\"2\" y=\"13\" width=\"9\" height=\"8\" rx=\"1\"/><rect x=\"13\" y=\"13\" width=\"9\" height=\"8\" rx=\"1\"/>\n        </svg>\n        <span>Muros de video</span>\n      </a></li>\n      <li><a href=\"#/reports\" class=\"nav-link\" data-view=\"reports\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/>\n        </svg>\n        <span>Informes</span>\n      </a></li>\n      <li><a href=\"#/integrations\" class=\"nav-link\" data-view=\"integrations\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M9 8v8M12 11v5M15 6v10\"/>\n        </svg>\n        <span>Integraciones</span>\n      </a></li>\n      <li><a href=\"#/activity\" class=\"nav-link\" data-view=\"activity\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/>\n        </svg>\n        <span>Actividad</span>\n      </a></li>\n      <li><a href=\"#/help\" class=\"nav-link\" data-view=\"help\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/>\n        </svg>\n        <span>Ayuda</span>\n      </a></li>\n      <li><a href=\"#/settings\" class=\"nav-link\" data-view=\"settings\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"12\" r=\"3\"/>\n          <path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"/>\n        </svg>\n        <span>Configuración</span>\n      </a></li>\n\n      <li id=\"adminNavItem\" style=\"display:none\"><a href=\"#/admin\" class=\"nav-link\" data-view=\"admin\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n        </svg>\n        <span>Administrador</span>\n      </a></li>\n    </ul>\n    <div class=\"sidebar-footer\">\n      <div class=\"connection-status\" id=\"connectionStatus\">\n        <span class=\"status-dot offline\"></span>\n        <span>Desconectado</span>\n      </div>\n    </div>\n  </nav>\n\n  <main class=\"content\" id=\"app\">\n    <!-- Views rendered here -->\n  </main>\n\n  <!-- Add Device Modal -->\n  <div class=\"modal-overlay\" id=\"addDeviceModal\" style=\"display:none\">\n    <div class=\"modal\" style=\"max-width:560px\">\n      <div class=\"modal-header\">\n        <h3>Agregar pantalla</h3>\n        <button class=\"btn-icon\" data-close-modal=\"addDeviceModal\">\n          <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/>\n          </svg>\n        </button>\n      </div>\n      <div class=\"modal-body\">\n        <p class=\"modal-description\" style=\"margin-bottom:16px\">Ingresa el código de vinculación de 6 dígitos mostrado en la pantalla.</p>\n        <div class=\"form-group\">\n          <label>Código de vinculación</label>\n          <input type=\"text\" id=\"pairingCodeInput\" maxlength=\"6\" pattern=\"[0-9]{6}\" placeholder=\"000000\" class=\"pairing-input\">\n        </div>\n        <div class=\"form-group\">\n          <label>Nombre (opcional)</label>\n          <input type=\"text\" id=\"deviceNameInput\" placeholder=\"p. ej., TV Vestíbulo\" class=\"input\">\n        </div>\n\n      </div>\n      <div class=\"modal-footer\">\n        <button class=\"btn btn-secondary\" data-close-modal=\"addDeviceModal\">Cancelar</button>\n        <button class=\"btn btn-primary\" id=\"pairDeviceBtn\">Vincular pantalla</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- Toast container -->\n  <div id=\"toastContainer\" class=\"toast-container\"></div>\n\n  <script type=\"module\" src=\"/js/app.js\"></script>\n</body>\n</html>\n"
